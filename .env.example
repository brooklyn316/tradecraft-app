# Copy this to .env.local and fill in your values
# Get these from your Supabase project: Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Alpha Vantage — get free key at alphavantage.co/support/#api-key
# Only used server-side via the Supabase Edge Function (never exposed to client)
ALPHA_VANTAGE_KEY=your-alpha-vantage-key-here

# Set in Vercel dashboard too (for production)
